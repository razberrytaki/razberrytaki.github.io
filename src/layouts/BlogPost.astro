
---
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';

type Props = CollectionEntry<'blog'>['data'];

const { title, description, pubDate, updatedDate, tags, sourceBoundary } = Astro.props;
---

<html lang="ko">
  <head>
    <BaseHead title={title} description={description} />
    <style>
      main { width: calc(100% - 2em); max-width: 100%; margin: 0; }
      .prose { width: 760px; max-width: calc(100% - 2em); margin: auto; padding: 2em 1em 4em; color: rgb(var(--gray-dark)); }
      .title { margin-bottom: 2em; padding: 2em 0 1em; text-align: left; }
      .title h1 { margin: 0.35em 0; }
      .date { color: rgb(var(--gray)); }
      .last-updated-on { font-style: italic; }
      .source-boundary { border: 1px solid rgb(var(--gray-light)); background: rgba(255,255,255,0.75); border-radius: 14px; padding: 0.8rem 1rem; color: rgb(var(--gray)); font-size: 0.92rem; }
    </style>
  </head>
  <body>
    <Header />
    <main>
      <article class="prose">
        <div class="title">
          <div class="date">
            <FormattedDate date={pubDate} />
            {updatedDate && <div class="last-updated-on">수정: <FormattedDate date={updatedDate} /></div>}
          </div>
          <h1>{title}</h1>
          <p>{description}</p>
          <ul class="badge-list">{tags.map((tag) => <li class="badge">{tag}</li>)}</ul>
        </div>
        <div class="source-boundary"><strong>공개 범위:</strong> {sourceBoundary}</div>
        <slot />
      </article>
    </main>
    <Footer />
  </body>
</html>
