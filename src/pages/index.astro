
---
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import FormattedDate from '../components/FormattedDate.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';

const posts = (await getCollection('blog')).filter((post) => !post.data.draft).sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()).slice(0, 3);
---

<!doctype html>
<html lang="ko">
  <head>
    <BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
    <style>
      .hero { padding: 4rem 0 2rem; }
      .eyebrow { color: var(--accent); font-weight: 700; margin-bottom: 0.75rem; }
      .hero p { max-width: 720px; color: rgb(var(--gray)); font-size: 1.12rem; }
      .actions { display: flex; flex-wrap: wrap; gap: 0.75rem; margin-top: 1.5rem; }
      .button { display: inline-block; border-radius: 999px; padding: 0.72rem 1rem; text-decoration: none; font-weight: 700; }
      .primary { background: rgb(var(--black)); color: white; }
      .secondary { border: 1px solid rgb(var(--gray-light)); color: rgb(var(--black)); background: white; }
      .section { margin-top: 3rem; }
      .post-list { list-style: none; padding: 0; display: grid; gap: 1rem; }
      .post-list a { text-decoration: none; color: inherit; }
      .post-list article { border: 1px solid rgb(var(--gray-light)); border-radius: 18px; padding: 1.1rem; background: rgba(255,255,255,0.85); }
      .post-list article:hover { box-shadow: var(--box-shadow); }
      .date { color: rgb(var(--gray)); font-size: 0.92rem; }
    </style>
  </head>
  <body>
    <Header />
    <main>
      <section class="hero">
        <div class="eyebrow">백엔드 · AI/RAG · 운영 · 디버깅</div>
        <h1>삽질한 만큼만 씁니다.</h1>
        <p>
          실험하다 막힌 것, 배포하다 깨진 것, 테스트로 잡은 것을 글로 남깁니다.
          비공개 메모는 따로 두고, 여기는 밖에 꺼내도 되는 이야기만 정리합니다.
        </p>
        <div class="actions">
          <a class="button primary" href="/blog/">글 보기</a>
          <a class="button secondary" href="/projects/">프로젝트 보기</a>
        </div>
      </section>

      <section class="section">
        <h2>주로 쓰는 것</h2>
        <div class="card-grid">
          <div class="card">
            <h3>근거를 남기는 RAG</h3>
            <p>답을 잘 만드는 것보다, 근거가 없을 때 멈추는 쪽에 관심이 많습니다.</p>
          </div>
          <div class="card">
            <h3>운영 중 만난 버그</h3>
            <p>PWA 캐시, WebView, 모바일 런타임처럼 책보다 로그가 먼저인 문제를 다룹니다.</p>
          </div>
          <div class="card">
            <h3>공개 저장소 다듬기</h3>
            <p>비밀값 검사, 의존성 점검, 과장된 설명 막기처럼 공개 전에 필요한 일을 적습니다.</p>
          </div>
        </div>
      </section>

      <section class="section">
        <h2>최근 글</h2>
        <ul class="post-list">
          {posts.map((post) => (
            <li>
              <a href={`/blog/${post.id}/`}>
                <article>
                  <div class="date"><FormattedDate date={post.data.pubDate} /></div>
                  <h3>{post.data.title}</h3>
                  <p>{post.data.description}</p>
                </article>
              </a>
            </li>
          ))}
        </ul>
      </section>
    </main>
    <Footer />
  </body>
</html>
